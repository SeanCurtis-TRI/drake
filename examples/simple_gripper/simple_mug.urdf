<?xml version="1.0"?>
<robot name='simple_mug'>
  <link name='main_body'>
    <inertial>
      <mass value="0.094"/>
      <origin xyz="0.01 0 0.05"/>
      <inertia ixx="0.000156" iyy="0.000156" izz="0.00015" ixy="0" ixz="0" iyz="0" />
    </inertial>

    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <cylinder radius="0.04" length="0.1"/>
      </geometry>
    </collision>

    <visual name='main_body_visual'>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <cylinder radius="0.04" length="0.1"/>
      </geometry>
      <material>
        <texture filename="rainbow.png"/>
      </material>
    </visual>

    <visual name='mug_handle_visual'>
      <!-- Half handle at the bottom of the mug -- contrast with the sdf file
           that has a half handle at the top.  -->
      <origin xyz="0.055 0 0.035"/>
      <geometry>
        <box size="0.03 0.02 0.04" />
      </geometry>
      <material>
        <texture filename="rainbow.png"/>
      </material>
    </visual>

  </link>
</robot>